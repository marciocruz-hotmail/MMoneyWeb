@page "/"
@page "/dashboard"

<PageTitle>Dashboard — MMoneyWeb</PageTitle>

<PageHeader Title="MMoneyWeb" Subtitle="Controle pessoal de contas">
    <Breadcrumb>
        <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
    </Breadcrumb>
</PageHeader>

<div class="alert alert-success" role="status">
    <i class="bi bi-check-circle me-2"></i>
    Fundação visual configurada com AdminLTE 4 e Bootstrap 5.
</div>

<div class="row g-3">
    <div class="col-sm-6 col-xl-3">
        <AppCard Title="Saldo total" CssClass="text-bg-primary">
            <p class="display-6 mb-0">—</p>
            <small class="opacity-75">Demonstração visual</small>
        </AppCard>
    </div>
    <div class="col-sm-6 col-xl-3">
        <AppCard Title="Contas" CssClass="text-bg-success">
            <p class="display-6 mb-0">—</p>
            <small class="opacity-75">Demonstração visual</small>
        </AppCard>
    </div>
    <div class="col-sm-6 col-xl-3">
        <AppCard Title="Lançamentos" CssClass="text-bg-warning">
            <p class="display-6 mb-0">—</p>
            <small class="opacity-75">Demonstração visual</small>
        </AppCard>
    </div>
    <div class="col-sm-6 col-xl-3">
        <AppCard Title="Cartões" CssClass="text-bg-info">
            <p class="display-6 mb-0">—</p>
            <small class="opacity-75">Demonstração visual</small>
        </AppCard>
    </div>
</div>
