@using MMoneyWeb.Web.Components
@using MMoneyWeb.Web.Components.Account.Shared
<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <MmoneyErrorBoundary @ref="errorBoundary">
            <ChildContent>
                <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                    <NotAuthorized>
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeRouteView>
            </ChildContent>
            <ErrorContent>
                <div class="p-3">
                    <p class="text-body-secondary mb-2">Ocorreu um erro não tratado. Verifique a mensagem exibida.</p>
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="RecuperarSecao">Tentar novamente</button>
                </div>
            </ErrorContent>
        </MmoneyErrorBoundary>
        <FocusOnNavigate RouteData="routeData" Selector="#main" />
    </Found>
</Router>

@code {
    private MmoneyErrorBoundary? errorBoundary;

    private void RecuperarSecao() => errorBoundary?.Recover();
}
